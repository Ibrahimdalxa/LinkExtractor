{
  "manifest_version": 3,
  "name": "Link Extractor",
  "version": "1.0.0",
  "description": "Scan any page and extract all download links — filter by type, copy or download instantly.",
  "permissions": ["scripting", "activeTab", "tabs", "downloads", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Link Extractor",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
